{
  "name": "nm-chronicles",
  "version": "0.0.0",
  "homepage": "https://brankovanov.github.io/nm-chronicles",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brankovanov/nm-chronicles.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:nm-chronicles": "node dist/nm-chronicles/server/server.mjs",
    "build:github-pages": "ng build --configuration githubPages",
    "postbuild:github-pages": "node scripts/prerender-gh-pages.js && node scripts/generate-seo-assets.js github-pages dist/github-pages/browser",
    "deploy:github-pages": "npx gh-pages -d dist/github-pages/browser -b gh-pages -r https://github.com/Brankovanov/nm-chronicles.git --dotfiles",
    "build:cloudflare": "ng build --configuration cloudflare",
    "postbuild:cloudflare": "node scripts/generate-seo-assets.js production dist/nm-chronicles-cloudflare/browser",
    "deploy:cloudflare": "npx wrangler publish --env production"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.2",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "simple-icons": "^16.26.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/compiler-cli": "^22.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "axe-core": "^4.12.1",
    "gh-pages": "^5.0.0",
    "jsdom": "^28.0.0",
    "lighthouse": "^13.4.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "wrangler": "^3.0.0"
  }
}
